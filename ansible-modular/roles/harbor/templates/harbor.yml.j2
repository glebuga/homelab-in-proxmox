# Конфигурационный файл Harbor (генерируется ролью 'harbor' по схеме v2.10.1).

# Имя хоста (FQDN) для доступа к веб-интерфейсу и реестру.
# Нельзя указывать localhost или 127.0.0.1 — Harbor должен быть доступен внешним клиентам.
hostname: {{ harbor_hostname }}

# Настройки HTTP.
http:
  # Порт HTTP. При включённом HTTPS сюда приходят запросы,
  # которые Harbor перенаправляет на HTTPS-порт.
  port: {{ harbor_http_port }}

# Настройки HTTPS.
https:
  # HTTPS-порт Harbor.
  port: {{ harbor_https_port }}
  # Пути к сертификату и приватному ключу (используются фронтендом nginx).
  certificate: {{ harbor_cert_dir }}/{{ harbor_cert_file }}
  private_key: {{ harbor_cert_dir }}/{{ harbor_key_file }}

internal_tls:
  enabled: false

# Начальный пароль администратора Harbor.
# Действует только при первой установке. Позже меняется через веб-интерфейс.
harbor_admin_password: "{{ harbor_admin_password }}"

# Настройки базы данных Harbor (PostgreSQL).
database:
  # Пароль суперпользователя БД обязательно сменить.
  password: "{{ harbor_db_password | default(harbor_admin_password) }}"
  max_idle_conns: 50
  # Максимальное число открытых соединений (<=0 — без лимита).
  max_open_conns: 100

# Каталог на хосте, где Harbor хранит свои данные (образы, БД и т.д.).
data_volume: {{ harbor_data_volume }}

# Хранилище артефактов. По умолчанию — локальная ФС (/data).
# Раскомментировать storage_service, чтобы использовать внешнее хранилище
# (S3, Azure, GCS, Swift, OSS).
# storage_service:
#   # ca_bundle — путь к корневому CA, который добавляется в доверенные
#   # контейнера registry (нужно для self-signed хранилищ).
#   ca_bundle:
#   # тип бэкенда: filesystem, azure, gcs, s3, swift, oss
#   filesystem:
#     maxthreads: 100
#   # disable: true — отключить редирект registry
#   redirect:
#     disable: false

# Настройки сканера уязвимостей Trivy.
{% if harbor_with_trivy %}
trivy:
  # ignore_unfixed: показывать только уязвимости, для которых есть исправление
  ignore_unfixed: false
  # skip_update: не качать базу Trivy из GitHub (актуально для CI/офлайна)
  skip_update: false
  # skip_java_db_update: не качать Java-базу Trivy
  skip_java_db_update: false
  # offline_scan: не ходить в сеть для определения зависимостей
  offline_scan: false
  # security_check: что искать — vuln (уязвимости), config, secret
  security_check: vuln
  # insecure: не проверять сертификат реестра
  insecure: false
{% else %}
trivy:
  enabled: false
{% endif %}

# Настройки сервиса задач (jobservice) — выполняет фоновые операции Harbor.
jobservice:
  # Максимальное число параллельных воркеров задач.
  max_job_workers: 10
  # Бэкенды логов задач: STD_OUTPUT, FILE и/или DB.
  job_loggers:
    - STD_OUTPUT
  # Как часто чистить логи задач (в днях; игнорируется при STD_OUTPUT).
  logger_sweeper_duration: 14

# Настройки уведомлений (webhook'и при событиях реестра).
notification:
  # Максимальное число повторов для webhook-задачи.
  webhook_job_max_retry: 3
  # Таймаут HTTP-клиента webhook-задачи (секунды).
  webhook_job_http_client_timeout: 3

# Настройки логирования Harbor.
log:
  # Уровень логов: debug, info, warning, error, fatal.
  level: info
  # Логи в локальной ФС хоста.
  local:
    # Сколько копий лога хранить до удаления (0 — удалять сразу).
    rotate_count: 50
    # Ротировать, когда файл вырастет больше этого размера.
    rotate_size: 200M
    # Каталог на хосте для логов Harbor.
    location: /var/log/harbor

# ChartMuseum (опционально) — хранилище Helm-чартов.
chart:
  absolute_url: disabled
{% if harbor_with_chartmuseum %}
chartmuseum:
  enabled: true
{% else %}
chartmuseum:
  enabled: false
{% endif %}

# Notary (опционально) — подписание и проверка образов.
{% if harbor_with_notary %}
notary:
  enabled: true
{% else %}
notary:
  enabled: false
{% endif %}

# Кэширующий слой (Redis) для метаданных артефактов — ускоряет pull при нагрузке.
cache:
  # По умолчанию выключен.
  enabled: false
  # Время жизни кэша (часы).
  expire_hours: 24
